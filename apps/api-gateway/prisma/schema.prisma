// WARZONE - SQLite Database Schema (Local Dev)
// Maintains parity with Pro PostgreSQL schema but using SQLite types.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Army {
  id           String    @id @default(uuid())
  name         String    @unique
  colorHex     String
  seasonScore  BigInt    @default(0)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users        User[]
  homeMatches  Match[]   @relation("HomeArmy")
  awayMatches  Match[]   @relation("AwayArmy")
  targetedRoasts Roast[]

  @@map("armies")
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String    @unique
  passwordHash    String?
  armyId          String
  rank            String    @default("Recruit")
  totalWarPoints  BigInt    @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  isActive        Boolean   @default(true)

  profilePictureUrl String?
  bio               String?

  army            Army      @relation(fields: [armyId], references: [id], onDelete: Restrict)
  ledger          PredictionLedger[]
  roasts          Roast[]
  roastUpvotes    RoastUpvote[]
  bunkersCreated  Bunker[]           @relation("BunkerCreator")
  bunkerMembers   BunkerMember[]
  posts           Post[]
  postReactions   PostReaction[]
  userBadges      UserBadge[]
  pointsLog       PointsLog[]
  lastLoginAt     DateTime?
  loginStreak     Int       @default(0)

  // SQLite index without unsupported sort/order constraints
  @@index([armyId])
  @@index([totalWarPoints])
  @@index([isActive, deletedAt])
  
  @@map("users")
}

model Match {
  id            String    @id @default(uuid())
  homeArmyId    String
  awayArmyId    String
  status        String    @default("PRE")
  startTime     DateTime

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  homeArmy      Army      @relation("HomeArmy", fields: [homeArmyId], references: [id], onDelete: Restrict)
  awayArmy      Army      @relation("AwayArmy", fields: [awayArmyId], references: [id], onDelete: Restrict)
  warRoom       WarRoom?
  predictions   Prediction[]
  bunkers       Bunker[]

  @@index([status, startTime])
  @@index([homeArmyId, awayArmyId])
  
  @@map("matches")
}

model WarRoom {
  id                  String    @id @default(uuid())
  matchId             String    @unique
  toxicityScoreHome   Int       @default(0)
  toxicityScoreAway   Int       @default(0)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  match               Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("war_rooms")
}

model Prediction {
  id             String    @id @default(uuid())
  matchId        String
  questionText   String
  optionA        String
  optionB        String
  correctOption  String?   // "A" or "B"
  pointsReward   Int
  status         String    @default("ACTIVE")
  expiresAt      DateTime

  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  match          Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  ledger         PredictionLedger[]

  @@index([matchId, status])
  
  @@map("predictions")
}

model PredictionLedger {
  id             String    @id @default(uuid())
  userId         String
  predictionId   String
  selectedOption String    // "A" or "B"
  pointsAwarded  Int       @default(0)

  clientIp       String?
  createdAt      DateTime  @default(now())

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  prediction     Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@unique([userId, predictionId], name: "unique_user_prediction")
  @@index([predictionId, selectedOption])
  
  @@map("prediction_ledger")
}

model Roast {
  id            String    @id @default(uuid())
  userId        String
  targetArmyId  String
  content       String
  upvoteCount   Int       @default(0)
  isLegendary   Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetArmy    Army      @relation(fields: [targetArmyId], references: [id], onDelete: Restrict)
  upvotes       RoastUpvote[]

  @@index([targetArmyId, upvoteCount])
  @@index([createdAt])
  @@map("roasts")
}

model RoastUpvote {
  id        String   @id @default(uuid())
  roastId   String
  userId    String
  createdAt DateTime @default(now())

  roast     Roast    @relation(fields: [roastId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roastId], name: "unique_user_roast_upvote")
  @@map("roast_upvotes")
}

model Bunker {
  id          String   @id @default(uuid())
  name        String
  inviteCode  String   @unique
  matchId     String
  creatorId   String
  createdAt   DateTime @default(now())

  match       Match    @relation(fields: [matchId], references: [id])
  creator     User     @relation("BunkerCreator", fields: [creatorId], references: [id])
  members     BunkerMember[]

  @@map("bunkers")
}

model BunkerMember {
  id        String   @id @default(uuid())
  bunkerId  String
  userId    String
  joinedAt  DateTime @default(now())

  bunker    Bunker   @relation(fields: [bunkerId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bunkerId, userId])
  @@map("bunker_members")
}

model Post {
  id          String    @id @default(uuid())
  userId      String
  content     String
  imageUrl    String?
  type        String    @default("OPINION")  // OPINION, HYPE, DEBATE, MEME
  
  fireCount      Int    @default(0)
  clownCount     Int    @default(0)
  toxicCount     Int    @default(0)
  laughCount     Int    @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions   PostReaction[]

  @@index([createdAt])
  @@index([fireCount])
  @@map("posts")
}

model PostReaction {
  id          String    @id @default(uuid())
  postId      String
  userId      String
  type        String    // FIRE, ROAST, DISAGREE, LEGEND
  createdAt   DateTime  @default(now())

  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type], name: "unique_user_post_reaction")
  @@index([postId])
  @@map("post_reactions")
}

model OtpStore {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Badge {
  id          String      @id @default(uuid())
  key         String      @unique
  name        String
  description String
  icon        String
  category    String      @default("COMBAT")
  maxProgress Int         @default(50)

  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  tier      String   @default("BRONZE")
  progress  Int      @default(0)
  isPinned  Boolean  @default(false)
  earnedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model SniperDuel {
  id            String    @id @default(uuid())
  topicText     String
  topicCategory String    @default("hot-take")

  player1Id     String
  player1Name   String
  player1Army   String
  player1Color  String

  player2Id     String
  player2Name   String
  player2Army   String
  player2Color  String

  messages      String    @default("[]")   // JSON array of messages
  status        String    @default("voting") // voting, completed

  player1Votes  Int       @default(0)
  player2Votes  Int       @default(0)
  hypeCount     Int       @default(0)

  winnerId      String?

  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  verdictAt     DateTime?
  createdAt     DateTime  @default(now())

  votes         DuelVote[]
  hypes         DuelHype[]

  @@index([createdAt])
  @@index([hypeCount])
  @@map("sniper_duels")
}

model DuelVote {
  id        String    @id @default(uuid())
  duelId    String
  userId    String
  votedFor  String    // 'player1' or 'player2'
  createdAt DateTime  @default(now())

  duel      SniperDuel @relation(fields: [duelId], references: [id], onDelete: Cascade)

  @@unique([duelId, userId])
  @@map("duel_votes")
}

model DuelHype {
  id        String    @id @default(uuid())
  duelId    String
  userId    String
  createdAt DateTime  @default(now())

  duel      SniperDuel @relation(fields: [duelId], references: [id], onDelete: Cascade)

  @@unique([duelId, userId])
  @@map("duel_hypes")
}

model PointsLog {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  source    String   // e.g. 'PREDICTION_CORRECT', 'DUEL_WIN', 'POST_CREATE'
  sourceId  String?  // FK to the originating entity (predictionId, duelId, postId, etc.)
  metadata  String?  // Optional JSON string for extra context

  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, source, createdAt])
  @@index([userId, sourceId])
  @@map("points_log")
}
