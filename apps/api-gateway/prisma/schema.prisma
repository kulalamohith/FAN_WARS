// WARZONE - SQLite Database Schema (Local Dev)
// Maintains parity with Pro PostgreSQL schema but using SQLite types.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Army {
  id           String    @id @default(uuid())
  name         String    @unique
  colorHex     String
  seasonScore  BigInt    @default(0)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users        User[]
  homeMatches  Match[]   @relation("HomeArmy")
  awayMatches  Match[]   @relation("AwayArmy")
  targetedRoasts Roast[]

  @@map("armies")
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  phoneNumber     String    @unique
  armyId          String
  rank            String    @default("Recruit")
  totalWarPoints  BigInt    @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  isActive        Boolean   @default(true)

  army            Army      @relation(fields: [armyId], references: [id], onDelete: Restrict)
  ledger          PredictionLedger[]
  roasts          Roast[]
  roastUpvotes    RoastUpvote[]
  bunkersCreated  Bunker[]           @relation("BunkerCreator")
  bunkerMembers   BunkerMember[]
  posts           Post[]
  postReactions   PostReaction[]

  // SQLite index without unsupported sort/order constraints
  @@index([armyId])
  @@index([totalWarPoints])
  @@index([isActive, deletedAt])
  
  @@map("users")
}

model Match {
  id            String    @id @default(uuid())
  homeArmyId    String
  awayArmyId    String
  status        String    @default("PRE")
  startTime     DateTime

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  homeArmy      Army      @relation("HomeArmy", fields: [homeArmyId], references: [id], onDelete: Restrict)
  awayArmy      Army      @relation("AwayArmy", fields: [awayArmyId], references: [id], onDelete: Restrict)
  warRoom       WarRoom?
  predictions   Prediction[]
  bunkers       Bunker[]

  @@index([status, startTime])
  @@index([homeArmyId, awayArmyId])
  
  @@map("matches")
}

model WarRoom {
  id                  String    @id @default(uuid())
  matchId             String    @unique
  toxicityScoreHome   Int       @default(0)
  toxicityScoreAway   Int       @default(0)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  match               Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("war_rooms")
}

model Prediction {
  id             String    @id @default(uuid())
  matchId        String
  questionText   String
  optionA        String
  optionB        String
  correctOption  String?   // "A" or "B"
  pointsReward   Int
  status         String    @default("ACTIVE")
  expiresAt      DateTime

  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  match          Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  ledger         PredictionLedger[]

  @@index([matchId, status])
  
  @@map("predictions")
}

model PredictionLedger {
  id             String    @id @default(uuid())
  userId         String
  predictionId   String
  selectedOption String    // "A" or "B"
  pointsAwarded  Int       @default(0)

  clientIp       String?
  createdAt      DateTime  @default(now())

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  prediction     Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)

  @@unique([userId, predictionId], name: "unique_user_prediction")
  @@index([predictionId, selectedOption])
  
  @@map("prediction_ledger")
}

model Roast {
  id            String    @id @default(uuid())
  userId        String
  targetArmyId  String
  content       String
  upvoteCount   Int       @default(0)
  isLegendary   Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetArmy    Army      @relation(fields: [targetArmyId], references: [id], onDelete: Restrict)
  upvotes       RoastUpvote[]

  @@index([targetArmyId, upvoteCount])
  @@index([createdAt])
  @@map("roasts")
}

model RoastUpvote {
  id        String   @id @default(uuid())
  roastId   String
  userId    String
  createdAt DateTime @default(now())

  roast     Roast    @relation(fields: [roastId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roastId], name: "unique_user_roast_upvote")
  @@map("roast_upvotes")
}

model Bunker {
  id          String   @id @default(uuid())
  name        String
  inviteCode  String   @unique
  matchId     String
  creatorId   String
  createdAt   DateTime @default(now())

  match       Match    @relation(fields: [matchId], references: [id])
  creator     User     @relation("BunkerCreator", fields: [creatorId], references: [id])
  members     BunkerMember[]

  @@map("bunkers")
}

model BunkerMember {
  id        String   @id @default(uuid())
  bunkerId  String
  userId    String
  joinedAt  DateTime @default(now())

  bunker    Bunker   @relation(fields: [bunkerId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bunkerId, userId])
  @@map("bunker_members")
}

model Post {
  id          String    @id @default(uuid())
  userId      String
  content     String
  type        String    @default("OPINION")  // OPINION, HYPE, DEBATE, MEME
  
  fireCount      Int    @default(0)
  roastCount     Int    @default(0)
  disagreeCount  Int    @default(0)
  legendCount    Int    @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions   PostReaction[]

  @@index([createdAt])
  @@index([fireCount])
  @@map("posts")
}

model PostReaction {
  id          String    @id @default(uuid())
  postId      String
  userId      String
  type        String    // FIRE, ROAST, DISAGREE, LEGEND
  createdAt   DateTime  @default(now())

  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type], name: "unique_user_post_reaction")
  @@index([postId])
  @@map("post_reactions")
}
