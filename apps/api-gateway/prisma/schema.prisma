generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Army {
  id             String   @id @default(uuid())
  name           String   @unique
  colorHex       String
  seasonScore    BigInt   @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  awayMatches    Match[]  @relation("AwayArmy")
  homeMatches    Match[]  @relation("HomeArmy")
  targetedRoasts Roast[]
  users          User[]

  @@map("armies")
}

model User {
  id                String             @id @default(uuid())
  username          String             @unique
  email             String             @unique
  passwordHash      String?
  armyId            String
  rank              String             @default("Recruit")
  totalWarPoints    BigInt             @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  isActive          Boolean            @default(true)
  lastLoginAt       DateTime?
  loginStreak       Int                @default(0)
  bio               String?
  profilePictureUrl String?
  bunkerMembers     BunkerMember[]
  bunkersCreated    Bunker[]           @relation("BunkerCreator")
  pointsLog         PointsLog[]
  postReactions     PostReaction[]
  posts             Post[]
  ledger            PredictionLedger[]
  roastUpvotes      RoastUpvote[]
  roasts            Roast[]
  userBadges        UserBadge[]
  army              Army               @relation(fields: [armyId], references: [id])

  @@index([armyId])
  @@index([totalWarPoints])
  @@index([isActive, deletedAt])
  @@map("users")
}

model Match {
  id          String       @id @default(uuid())
  homeArmyId  String
  awayArmyId  String
  status      String       @default("PRE")
  startTime   DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  bunkers     Bunker[]
  awayArmy    Army         @relation("AwayArmy", fields: [awayArmyId], references: [id])
  homeArmy    Army         @relation("HomeArmy", fields: [homeArmyId], references: [id])
  predictions Prediction[]
  warRoom     WarRoom?

  @@index([status, startTime])
  @@index([homeArmyId, awayArmyId])
  @@map("matches")
}

model WarRoom {
  id                String   @id @default(uuid())
  matchId           String   @unique
  toxicityScoreHome Int      @default(0)
  toxicityScoreAway Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  match             Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("war_rooms")
}

model Prediction {
  id            String             @id @default(uuid())
  matchId       String
  questionText  String
  optionA       String
  optionB       String
  correctOption String?
  pointsReward  Int
  status        String             @default("ACTIVE")
  expiresAt     DateTime
  createdBy     String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?
  ledger        PredictionLedger[]
  match         Match              @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, status])
  @@map("predictions")
}

model PredictionLedger {
  id             String     @id @default(uuid())
  userId         String
  predictionId   String
  selectedOption String
  pointsAwarded  Int        @default(0)
  clientIp       String?
  createdAt      DateTime   @default(now())
  prediction     Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, predictionId], name: "unique_user_prediction")
  @@index([predictionId, selectedOption])
  @@map("prediction_ledger")
}

model Roast {
  id           String        @id @default(uuid())
  userId       String
  targetArmyId String
  content      String
  upvoteCount  Int           @default(0)
  isLegendary  Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  upvotes      RoastUpvote[]
  targetArmy   Army          @relation(fields: [targetArmyId], references: [id])
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetArmyId, upvoteCount])
  @@index([createdAt])
  @@map("roasts")
}

model RoastUpvote {
  id        String   @id @default(uuid())
  roastId   String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roast     Roast    @relation(fields: [roastId], references: [id], onDelete: Cascade)

  @@unique([userId, roastId], name: "unique_user_roast_upvote")
  @@map("roast_upvotes")
}

model Bunker {
  id         String         @id @default(uuid())
  name       String
  inviteCode String         @unique
  matchId    String
  creatorId  String
  createdAt  DateTime       @default(now())
  members    BunkerMember[]
  creator    User           @relation("BunkerCreator", fields: [creatorId], references: [id])
  match      Match          @relation(fields: [matchId], references: [id])

  @@map("bunkers")
}

model BunkerMember {
  id       String   @id @default(uuid())
  bunkerId String
  userId   String
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bunker   Bunker   @relation(fields: [bunkerId], references: [id], onDelete: Cascade)

  @@unique([bunkerId, userId])
  @@map("bunker_members")
}

model Post {
  id         String         @id @default(uuid())
  userId     String
  content    String
  imageUrl   String?
  type       String         @default("OPINION")
  fireCount  Int            @default(0)
  clownCount Int            @default(0)
  toxicCount Int            @default(0)
  laughCount Int            @default(0)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?
  reactions  PostReaction[]
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([fireCount])
  @@map("posts")
}

model PostReaction {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type], name: "unique_user_post_reaction")
  @@index([postId])
  @@map("post_reactions")
}

model OtpStore {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Badge {
  id          String      @id @default(uuid())
  key         String      @unique
  name        String
  description String
  icon        String
  category    String      @default("COMBAT")
  maxProgress Int         @default(50)
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  tier     String   @default("BRONZE")
  progress Int      @default(0)
  isPinned Boolean  @default(false)
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model SniperDuel {
  id            String     @id @default(uuid())
  topicText     String
  topicCategory String     @default("hot-take")
  player1Id     String
  player1Name   String
  player1Army   String
  player1Color  String
  player2Id     String
  player2Name   String
  player2Army   String
  player2Color  String
  messages      String     @default("[]")
  status        String     @default("voting")
  player1Votes  Int        @default(0)
  player2Votes  Int        @default(0)
  hypeCount     Int        @default(0)
  winnerId      String?
  startedAt     DateTime   @default(now())
  endedAt       DateTime?
  verdictAt     DateTime?
  createdAt     DateTime   @default(now())
  hypes         DuelHype[]
  votes         DuelVote[]

  @@index([createdAt])
  @@index([hypeCount])
  @@map("sniper_duels")
}

model DuelVote {
  id        String     @id @default(uuid())
  duelId    String
  userId    String
  votedFor  String
  createdAt DateTime   @default(now())
  duel      SniperDuel @relation(fields: [duelId], references: [id], onDelete: Cascade)

  @@unique([duelId, userId])
  @@map("duel_votes")
}

model DuelHype {
  id        String     @id @default(uuid())
  duelId    String
  userId    String
  createdAt DateTime   @default(now())
  duel      SniperDuel @relation(fields: [duelId], references: [id], onDelete: Cascade)

  @@unique([duelId, userId])
  @@map("duel_hypes")
}

model PointsLog {
  id        String   @id @default(uuid())
  userId    String
  amount    Int
  source    String
  sourceId  String?
  metadata  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, source, createdAt])
  @@index([userId, sourceId])
  @@map("points_log")
}

model BunkerPrediction {
  id           String   @id @default(uuid())
  bunkerId     String
  creatorId    String
  question     String
  optionA      String
  optionB      String
  votesA       Int      @default(0)
  votesB       Int      @default(0)
  status       String   @default("ACTIVE") // ACTIVE, CLOSED
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  bunker       Bunker   @relation(fields: [bunkerId], references: [id], onDelete: Cascade)
  creator      User     @relation(fields: [creatorId], references: [id])
  votes        BunkerPredictionVote[]

  @@map("bunker_predictions")
}

model BunkerPredictionVote {
  id           String           @id @default(uuid())
  predictionId String
  userId       String
  option       String           // "A" or "B"
  createdAt    DateTime         @default(now())
  prediction   BunkerPrediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id])

  @@unique([predictionId, userId])
  @@map("bunker_prediction_votes")
}

model BunkerJinxBattle {
  id          String   @id @default(uuid())
  bunkerId    String
  creatorId   String
  prompt      String
  countA      Int      @default(0) // JINXING
  countB      Int      @default(0) // ANTI-JINXING
  winner      String?
  startedAt   DateTime @default(now())
  expiresAt   DateTime
  bunker      Bunker   @relation(fields: [bunkerId], references: [id], onDelete: Cascade)
  creator     User     @relation(fields: [creatorId], references: [id])

  @@map("bunker_jinx_battles")
}
