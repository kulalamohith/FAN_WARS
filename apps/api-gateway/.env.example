# ===========================================
# WARZONE API Gateway — Environment Variables
# ===========================================
# Copy this file to .env and fill in values.
# In production, inject these via K8s secrets / Docker env.

# --- Server ---
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=debug

# --- CORS ---
CORS_ORIGIN=*

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://warzone:warzone@localhost:5432/warzone

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=warzone-dev-secret-change-in-production!!
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d
